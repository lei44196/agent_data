        JOIN dim_product dp2 ON fo2.product_id = dp2.product_id
        WHERE d2.year = d.year AND d2.month = d.month
        GROUP BY d2.year, d2.month, dp2.product_name
    ) monthly_sales
    WHERE monthly_sales.year = d.year AND monthly_sales.month = d.month
)
ORDER BY d.year, d.month;
